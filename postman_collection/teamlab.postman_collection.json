      "name": "Auth",
      "item": [
        {
          "name": "Register Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test(\"Owner created\", function () {",
                  "  pm.expect(data).to.have.property(\"id\");",
                  "  pm.expect(data).to.have.property(\"email\");",
                  "  pm.expect(data).to.have.property(\"account_type\", \"owner\");",
                  "});",
                  "pm.environment.set(\"owner_id\", String(data.id));",
                  "pm.collectionVariables.set(\"owner_id\", String(data.id));",
                  "pm.collectionVariables.set(\"owner_email\", data.email);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"owner_{{$timestamp}}\",\"email\":\"owner_{{$timestamp}}@example.com\",\"password\":\"OwnerPass123!\",\"account_type\":\"owner\"}",
              "options": {
                "raw": {
